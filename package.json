{
  "name": "safedelay",
  "version": "1.0.0",
  "description": "Time-locked wallet smart contract for Bitcoin Cash",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/types/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": "./src/types/index.ts",
    "./artifacts/SafeDelay": "./artifacts/SafeDelay.artifact.json",
    "./artifacts/SafeDelayMultiSig": "./artifacts/SafeDelayMultiSig.artifact.json"
  },
  "files": [
    "artifacts/",
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc",
    "compile": "cashc src/SafeDelay.cash --hex --output dist/",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.json"
  },
  "keywords": [
    "cashscript",
    "bitcoin-cash",
    "smart-contract",
    "timelock",
    "wallet"
  ],
  "author": "Lifestone Labs",
  "license": "MIT",
  "dependencies": {
    "cashscript": "^0.10.5"
  },
  "devDependencies": {
    "@bitauth/libauth": "^3.0.0",
    "@cashscript/utils": "^0.12.1",
    "cashc": "^0.12.1",
    "jest": "^30.3.0",
    "typescript": "^5.0.0"
  }
}
