{
  "name": "safedelay",
  "version": "1.0.1",
  "description": "Time-locked wallet smart contract library for Bitcoin Cash",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./artifacts/SafeDelay": "./artifacts/SafeDelay.artifact.json",
    "./artifacts/SafeDelayMultiSig": "./artifacts/SafeDelayMultiSig.artifact.json",
    "./artifacts/SafeDelayStreaming": "./artifacts/SafeDelayStreaming.artifact.json",
    "./artifacts/SafeDelay_NFT": "./artifacts/SafeDelay_NFT.artifact.json",
    "./artifacts/CrowdFund": "./artifacts/CrowdFund.artifact.json",
    "./artifacts/SocialRecovery": "./artifacts/SocialRecovery.artifact.json"
  },
  "files": [
    "dist",
    "artifacts"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "node --input-type=module -e \"import {cpSync, mkdirSync} from 'fs'; mkdirSync('dist/demos', {recursive: true}); cpSync('index.html', 'dist/index.html'); for(const f of ['cancel-refund.html','create-lock.html','extend-lock.html']) cpSync('demo/'+f, 'dist/demos/'+f);\"",
    "compile": "cashc src/SafeDelay.cash --hex --output artifacts/",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cashscript",
    "bitcoin-cash",
    "smart-contract",
    "timelock",
    "wallet"
  ],
  "author": "Lifestone Labs",
  "license": "MIT",
  "dependencies": {
    "cashscript": "^0.12.1"
  },
  "devDependencies": {
    "@bitauth/libauth": "^3.0.0",
    "@cashscript/utils": "^0.12.1",
    "cashc": "^0.12.1",
    "jest": "^30.3.0",
    "typescript": "^5.0.0"
  }
}
