# SafeDelay Frontend Environment Variables
# Copy this file to .env and fill in your values

# WalletConnect Project ID (required for WalletConnect/AppKit functionality)
# Get one free at https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Electrum RPC endpoints (optional — defaults provided if not set)
# Mainnet
# VITE_ELECTRUM_MAINNET=https://electroncash.deified.net:50004
# Testnet (Chipnet)
# VITE_ELECTRUM_TESTNET=https://electroncash.deified.net:51004
